# --- Client-Side Variables (VITE_ prefix required) ---
# Paste your Supabase Project URL (e.g., https://xyz.supabase.co)
VITE_SUPABASE_URL=

# Paste your Supabase Anon Key (found in API settings)
VITE_SUPABASE_ANON_KEY=

# --- Server-Side Secrets (Internal use only) ---
# Gemini API Key (This is automatically set in many cases by the platform)
GEMINI_API_KEY=
